{
  "name": "@intrect/openswarm",
  "version": "0.4.1",
  "description": "Autonomous AI agent orchestrator — Claude, GPT, Codex, and local models (Ollama/LMStudio/llama.cpp)",
  "license": "GPL-3.0",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "openswarm": "dist/cli.js"
  },
  "files": [
    "dist",
    "config.example.yaml",
    "templates",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "predev": "pkill -f 'tsx src/index.ts' 2>/dev/null || true",
    "dev": "node --env-file=.env --import=tsx src/index.ts",
    "prestart": "pkill -f 'dist/index.js' 2>/dev/null || true",
    "build": "tsc",
    "start": "node --env-file=.env dist/index.js",
    "stop": "pkill -f 'node --env-file=.env.*openswarm' 2>/dev/null || echo 'No process running'",
    "lint": "oxlint src/",
    "typecheck": "tsc --noEmit",
    "test": "node --experimental-vm-modules node_modules/vitest/vitest.mjs run",
    "test:watch": "node --experimental-vm-modules node_modules/vitest/vitest.mjs",
    "chat": "node --env-file=.env --import=tsx src/support/chat.ts",
    "cli:dev": "node --env-file=.env --import=tsx src/cli.ts",
    "perf:measure": "tsx scripts/playwright-rendering-performance.ts",
    "ci": "npm run lint && npm run typecheck && npm run build",
    "service:install": "bash scripts/install-service.sh",
    "service:start": "bash scripts/manage-service.sh start",
    "service:stop": "bash scripts/manage-service.sh stop",
    "service:restart": "bash scripts/manage-service.sh restart",
    "service:status": "bash scripts/manage-service.sh status",
    "service:uninstall": "bash scripts/manage-service.sh uninstall",
    "service:logs": "bash scripts/manage-service.sh logs stdout",
    "service:errors": "bash scripts/manage-service.sh logs stderr",
    "browser:install": "bash scripts/install-browser-launcher.sh",
    "browser:uninstall": "bash scripts/uninstall-browser-launcher.sh"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.72.1",
    "@intrect/openswarm": "^0.2.1",
    "@lancedb/lancedb": "^0.23.0",
    "@linear/sdk": "^19.0.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/blessed": "^0.1.27",
    "@xenova/transformers": "^2.17.2",
    "apache-arrow": "^18.1.0",
    "better-sqlite3": "^12.8.0",
    "blessed": "^0.1.81",
    "commander": "^12.1.0",
    "croner": "^8.0.0",
    "discord.js": "^14.14.1",
    "graphql": "^16.13.2",
    "graphql-yoga": "^5.19.0",
    "nanoid": "^5.1.7",
    "yaml": "^2.8.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^4.0.18",
    "bun-types": "^1.1.0",
    "oxlint": "^1.43.0",
    "playwright": "^1.47.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=22"
  }
}
